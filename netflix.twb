      <column caption='Movie %' datatype='real' name='[Calculation_0996168246394881]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='ROUND(COUNT(IF [type] = &quot;Movie&quot; THEN [show_id] END) / COUNT([show_id]) * 100, 1)' />
